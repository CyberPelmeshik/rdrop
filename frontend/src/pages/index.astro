<!doctype html>
<html lang="ru">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="generator" content={Astro.generator} />
        <title>rDrop — обмен файлами</title>
        <style>
            :root {
                --bg: #0d1117;
                --surface: #161b22;
                --border: #30363d;
                --text: #e6edf3;
                --text-muted: #8b949e;
                --accent: #58a6ff;
                --accent-hover: #79c0ff;
                --green: #3fb950;
                --green-dim: #238636;
                --red: #f85149;
                --radius: 8px;
                --font: "Segoe UI", system-ui, -apple-system, sans-serif;
            }

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                font-family: var(--font);
                background: var(--bg);
                color: var(--text);
                height: 100vh;
                display: flex;
                flex-direction: column;
                overflow: hidden;
            }

            /* ---- Header ---- */
            header {
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 12px 24px;
                background: var(--surface);
                border-bottom: 1px solid var(--border);
                flex-shrink: 0;
            }

            .logo {
                display: flex;
                align-items: center;
                gap: 10px;
                font-size: 1.3rem;
                font-weight: 700;
                letter-spacing: -0.3px;
            }

            .logo-icon {
                width: 32px;
                height: 32px;
                background: linear-gradient(135deg, var(--accent), #a371f7);
                border-radius: var(--radius);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1rem;
            }

            .name-row {
                display: flex;
                align-items: center;
                gap: 8px;
            }

            .name-row input {
                padding: 6px 12px;
                border: 1px solid var(--border);
                border-radius: var(--radius);
                background: var(--bg);
                color: var(--text);
                font-size: 0.9rem;
                width: 180px;
                outline: none;
                transition: border-color 0.15s;
            }

            .name-row input:focus {
                border-color: var(--accent);
            }

            .status-badge {
                font-size: 0.75rem;
                padding: 4px 10px;
                border-radius: 12px;
                font-weight: 500;
            }

            .status-badge.connected {
                background: rgba(63, 185, 80, 0.15);
                color: var(--green);
            }

            .status-badge.disconnected {
                background: rgba(248, 81, 73, 0.15);
                color: var(--red);
            }

            .status-badge.connecting {
                background: rgba(210, 153, 34, 0.15);
                color: #d29922;
                animation: pulse 1.5s ease-in-out infinite;
            }

            @keyframes pulse {
                0%,
                100% {
                    opacity: 1;
                }
                50% {
                    opacity: 0.5;
                }
            }

            /* ---- Buttons ---- */
            button {
                cursor: pointer;
                border: none;
                border-radius: var(--radius);
                font-family: var(--font);
                font-size: 0.85rem;
                font-weight: 500;
                transition: all 0.15s;
            }

            .btn-primary {
                background: var(--green-dim);
                color: #fff;
                padding: 6px 14px;
            }

            .btn-primary:hover {
                background: var(--green);
            }

            .btn-select {
                background: transparent;
                color: var(--accent);
                border: 1px solid var(--border);
                padding: 4px 12px;
                font-size: 0.8rem;
            }

            .btn-select:hover {
                background: rgba(88, 166, 255, 0.1);
                border-color: var(--accent);
            }

            .btn-download {
                background: transparent;
                color: var(--accent);
                border: 1px solid var(--border);
                padding: 4px 12px;
                font-size: 0.8rem;
                text-decoration: none;
                border-radius: var(--radius);
                display: inline-block;
                transition: all 0.15s;
            }

            .btn-download:hover {
                background: rgba(88, 166, 255, 0.1);
                border-color: var(--accent);
            }

            /* ---- Layout ---- */
            .main-layout {
                display: flex;
                flex: 1;
                overflow: hidden;
            }

            /* ---- Sidebar ---- */
            .sidebar {
                width: 280px;
                background: var(--surface);
                border-right: 1px solid var(--border);
                display: flex;
                flex-direction: column;
                flex-shrink: 0;
            }

            .sidebar-header {
                padding: 16px 16px 10px;
                font-size: 0.8rem;
                text-transform: uppercase;
                letter-spacing: 0.6px;
                color: var(--text-muted);
                display: flex;
                justify-content: space-between;
                align-items: center;
            }

            .sidebar-header .count {
                background: var(--border);
                padding: 2px 8px;
                border-radius: 10px;
                font-size: 0.7rem;
                color: var(--text);
            }

            .user-list {
                list-style: none;
                overflow-y: auto;
                flex: 1;
                padding: 0 8px 8px;
            }

            .user-item {
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 10px 12px;
                border-radius: var(--radius);
                transition: background 0.12s;
            }

            .user-item:hover {
                background: rgba(255, 255, 255, 0.04);
            }

            .user-item.selected {
                background: rgba(88, 166, 255, 0.08);
                border: 1px solid rgba(88, 166, 255, 0.25);
            }

            .user-avatar {
                width: 34px;
                height: 34px;
                border-radius: 50%;
                background: linear-gradient(135deg, var(--accent), #a371f7);
                display: flex;
                align-items: center;
                justify-content: center;
                font-weight: 700;
                font-size: 0.85rem;
                flex-shrink: 0;
            }

            .user-name {
                flex: 1;
                overflow: hidden;
                text-overflow: ellipsis;
                white-space: nowrap;
                font-size: 0.9rem;
            }

            .empty-hint {
                color: var(--text-muted);
                font-size: 0.85rem;
                padding: 16px;
                text-align: center;
                list-style: none;
            }

            /* ---- Content area ---- */
            .content {
                flex: 1;
                display: flex;
                flex-direction: column;
                padding: 24px;
                overflow-y: auto;
                gap: 24px;
            }

            .panel {
                background: var(--surface);
                border: 1px solid var(--border);
                border-radius: var(--radius);
                padding: 20px;
            }

            .panel h2 {
                font-size: 1rem;
                font-weight: 600;
                margin-bottom: 16px;
                display: flex;
                align-items: center;
                gap: 8px;
            }

            .recipient-info {
                display: flex;
                align-items: center;
                gap: 8px;
                margin-bottom: 16px;
                padding: 10px 14px;
                background: var(--bg);
                border-radius: var(--radius);
                font-size: 0.9rem;
            }

            .recipient-info .label {
                color: var(--text-muted);
            }

            .recipient-info .value {
                color: var(--text-muted);
                font-style: italic;
            }

            .recipient-info .value.has-recipient {
                color: var(--accent);
                font-style: normal;
                font-weight: 500;
            }

            .file-row {
                display: flex;
                align-items: center;
                gap: 12px;
            }

            .file-row input[type="file"] {
                display: none;
            }

            .btn-file {
                background: var(--bg);
                color: var(--text);
                border: 1px dashed var(--border);
                padding: 10px 18px;
                border-radius: var(--radius);
                cursor: pointer;
                font-size: 0.85rem;
                transition: all 0.15s;
                display: flex;
                align-items: center;
                gap: 6px;
            }

            .btn-file:hover {
                border-color: var(--accent);
                color: var(--accent);
            }

            .file-name-label {
                font-size: 0.85rem;
                color: var(--text-muted);
                flex: 1;
                overflow: hidden;
                text-overflow: ellipsis;
                white-space: nowrap;
            }

            .file-list {
                list-style: none;
            }

            .file-item {
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 10px 0;
                border-bottom: 1px solid var(--border);
            }

            .file-item:last-child {
                border-bottom: none;
            }

            .file-time {
                font-size: 0.75rem;
                color: var(--text-muted);
                margin-left: auto;
            }

            /* ---- Scrollbar ---- */
            ::-webkit-scrollbar {
                width: 6px;
            }
            ::-webkit-scrollbar-track {
                background: transparent;
            }
            ::-webkit-scrollbar-thumb {
                background: var(--border);
                border-radius: 3px;
            }

            /* ---- Responsive ---- */
            @media (max-width: 640px) {
                .sidebar {
                    width: 100%;
                    max-height: 220px;
                    border-right: none;
                    border-bottom: 1px solid var(--border);
                }
                .main-layout {
                    flex-direction: column;
                }
                header {
                    flex-wrap: wrap;
                    gap: 8px;
                }
                .name-row input {
                    width: 120px;
                }
            }
        </style>
    </head>
    <body>
        <header>
            <div class="logo">
                <div class="logo-icon">📦</div>
                <span>rDrop</span>
            </div>
            <div class="name-row">
                <input
                    type="text"
                    id="name-input"
                    placeholder="Ваше имя..."
                    maxlength="30"
                    autocomplete="off"
                />
                <button class="btn-primary" id="name-save-btn">Сохранить</button
                >
            </div>
            <span class="status-badge connecting" id="connection-status">
                Подключение...
            </span>
        </header>

        <div class="main-layout">
            <aside class="sidebar">
                <div class="sidebar-header">
                    <span>Пользователи онлайн</span>
                    <span class="count" id="user-count">0</span>
                </div>
                <ul class="user-list" id="user-list">
                    <li class="empty-hint">Загрузка...</li>
                </ul>
            </aside>

            <main class="content">
                <!-- Send panel -->
                <div class="panel">
                    <h2>📤 Отправить файл</h2>
                    <div class="recipient-info">
                        <span class="label">Получатель:</span>
                        <span class="value" id="selected-user">не выбран</span>
                    </div>
                    <div class="file-row">
                        <label class="btn-file" for="file-input">
                            📎 Выбрать файл
                        </label>
                        <input type="file" id="file-input" />
                        <span class="file-name-label" id="file-name-label">
                            Файл не выбран
                        </span>
                        <button class="btn-primary" id="send-btn"
                            >Отправить</button
                        >
                    </div>
                </div>

                <!-- Received panel -->
                <div class="panel">
                    <h2>📥 Полученные файлы</h2>
                    <ul class="file-list" id="received-list">
                        <li class="empty-hint">Нет полученных файлов</li>
                    </ul>
                </div>
            </main>
        </div>

        <script src="/app.js" is:inline defer></script>
    </body>
</html>
